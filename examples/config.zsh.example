# ==============================================================================
# Configuration zanvil
# ==============================================================================
# Copiez ce fichier vers ~/.zanvil/config.zsh et personnalisez-le
# cp config.zsh.example config.zsh
#
# Les modules desactives ne seront pas charges au demarrage du shell
# ==============================================================================

# Modules disponibles (true = active, false = desactive)
ZANVIL_MODULE_GITLAB=true      # Scripts et fonctions GitLab
ZANVIL_MODULE_DOCKER=true      # Utilitaires Docker (dex, etc.)
ZANVIL_MODULE_MISE=true        # Gestionnaire de versions (Node, Java, Maven)
ZANVIL_MODULE_NUSHELL=true     # Integration Nushell
ZANVIL_MODULE_KUBE=true        # Gestionnaire de configs Kubernetes
ZANVIL_MODULE_POSTING=true     # Client HTTP TUI (posting)

# ==============================================================================
# Mise Configuration
# ==============================================================================
# mise est configure via ~/.config/mise/config.toml
# Les fichiers .nvmrc, .sdkmanrc et .tool-versions sont supportes nativement
# Voir: https://mise.jdx.dev/configuration.html

# ==============================================================================
# Auto-Update
# ==============================================================================
ZANVIL_AUTO_UPDATE=true        # Activer la verification des mises a jour
ZANVIL_UPDATE_FREQUENCY=7      # Frequence en jours (0 = a chaque demarrage)
ZANVIL_UPDATE_MODE="prompt"    # "prompt" = demander, "auto" = mise a jour silencieuse

# ==============================================================================
# Parametres avances (surchargeable)
# ==============================================================================
# ZANVIL_ZCOMPDUMP_CACHE_HOURS=24  # Cache compinit en heures (defaut: 24)
# ZANVIL_WORK_CACHE_TTL=300         # Cache contexte Work en secondes (defaut: 300)
# ZANVIL_WORK_TIMEOUT=2             # Timeout test reseau Work (defaut: 2s)
# ZANVIL_WORK_NEXUS_URL=""          # URL de probe pour detecter le contexte interne (voir env.d/work.zsh)
# ZANVIL_AI_CHARS_PER_TOKEN=4      # Ratio caracteres/token pour estimation AI
# ZANVIL_STARTUP_BANNER=false       # Coupe la banniere de demarrage (le splash install/update reste affiche)

# ==============================================================================
# Chargement des plugins
# ==============================================================================
ZANVIL_PLUGINS_ORG=zsh-users  # Org par defaut (optionnel)
ZANVIL_PLUGINS=(
    zsh-autosuggestions                       # Utilise l'org par defaut
    Aloxaf/fzf-tab                            # GitHub owner/repo
    # https://github.com/custom/plugin.git    # URL complete
)
